<ui:FluentWindow x:Class="SmsWorkbench.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                 xmlns:local="clr-namespace:SmsWorkbench"
                 Title="GPT Register Tool"
                 Width="1360" Height="860" MinWidth="1220" MinHeight="720"
                 WindowStartupLocation="CenterScreen"
                 Background="{DynamicResource AppBg}"
                 FontFamily="Segoe UI, Microsoft YaHei UI"
                 FontSize="13"
                 UseLayoutRounding="True"
                 SnapsToDevicePixels="True"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
  <ui:FluentWindow.Resources>
    <local:CollapsedLabelConverter x:Key="CollapsedLabelConverter"/>
    <Style x:Key="SidebarNavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="Margin" Value="0,0,0,10"/>
      <Setter Property="Height" Value="46"/>
      <Setter Property="Padding" Value="14,0"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Background" Value="{DynamicResource SidebarBg}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="12">
              <ContentPresenter Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PanelHover}"/>
                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource LineStrong}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PanelHover}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding SidebarCollapsed}" Value="True">
          <Setter Property="Width" Value="46"/>
          <Setter Property="HorizontalAlignment" Value="Center"/>
          <Setter Property="HorizontalContentAlignment" Value="Center"/>
          <Setter Property="Padding" Value="0"/>
          <Setter Property="Margin" Value="0,0,0,8"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="SidebarPaneBorderStyle" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource SidebarBg}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="Padding" Value="12"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding SidebarCollapsed}" Value="True">
          <Setter Property="Padding" Value="7"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="SidebarBrandLogoStyle" TargetType="Border">
      <Setter Property="Width" Value="40"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding SidebarCollapsed}" Value="True">
          <Setter Property="Visibility" Value="Collapsed"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="SidebarBrandTextPanelStyle" TargetType="StackPanel">
      <Setter Property="Margin" Value="10,0,0,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding SidebarCollapsed}" Value="True">
          <Setter Property="Visibility" Value="Collapsed"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="SidebarToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
      <Setter Property="Width" Value="34"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="Margin" Value="10,0,0,0"/>
      <Setter Property="HorizontalAlignment" Value="Right"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding SidebarCollapsed}" Value="True">
          <Setter Property="Grid.Column" Value="0"/>
          <Setter Property="Grid.ColumnSpan" Value="3"/>
          <Setter Property="Width" Value="46"/>
          <Setter Property="Height" Value="46"/>
          <Setter Property="Margin" Value="0"/>
          <Setter Property="HorizontalAlignment" Value="Center"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="SidebarScrollBarStyle" TargetType="{x:Type ScrollBar}">
      <Setter Property="Width" Value="0"/>
      <Setter Property="MinWidth" Value="0"/>
      <Setter Property="Opacity" Value="0"/>
      <Setter Property="Visibility" Value="Collapsed"/>
    </Style>
    <Style x:Key="SidebarLabelStyle" TargetType="TextBlock">
      <Setter Property="Margin" Value="10,0,0,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding SidebarCollapsed}" Value="True">
          <Setter Property="Visibility" Value="Collapsed"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="SidebarSectionHeaderStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="4,18,0,8"/>
      <Setter Property="TextWrapping" Value="NoWrap"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding SidebarCollapsed}" Value="True">
          <Setter Property="Visibility" Value="Collapsed"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
  </ui:FluentWindow.Resources>
  <materialDesign:DialogHost Identifier="RootDialogHost">
      <Grid Background="{DynamicResource AppBg}">
        <Grid.RowDefinitions>
          <RowDefinition Height="48"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

      <ui:TitleBar Grid.Row="0"
                   Title=""
                   Icon="{x:Null}"
                   ShowMinimize="True"
                   ShowMaximize="True"
                   ShowClose="True"
                   CloseWindowByDoubleClickOnIcon="False">
        <ui:TitleBar.Header>
            <Grid/>
        </ui:TitleBar.Header>
      </ui:TitleBar>

      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition x:Name="SidebarColumn" Width="272"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid x:Name="SidebarHost" Grid.Column="0" Margin="10,0,10,10" ClipToBounds="True" HorizontalAlignment="Stretch">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <Border Margin="0,0,0,10"
                  Style="{StaticResource SidebarPaneBorderStyle}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Border Style="{StaticResource SidebarBrandLogoStyle}">
                <Image Source="Assets/black-kitten.png" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <StackPanel Grid.Column="1" Style="{StaticResource SidebarBrandTextPanelStyle}" Margin="10,0,8,0">
                <TextBlock Text="GPT Register Tool" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="Fluent account workbench" FontSize="10.5" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
              </StackPanel>
              <Button x:Name="SidebarToggleButton"
                      Grid.Column="2"
                      Style="{StaticResource SidebarToggleButtonStyle}"
                      ToolTip="收起侧边栏"
                      Click="ToggleSidebar_Click">
                <Path Width="16"
                      Height="16"
                      Stretch="Uniform"
                      Data="{Binding SidebarToggleGeometry}"
                      Stroke="{DynamicResource TextMain}"
                      StrokeThickness="1.8"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
              </Button>
            </Grid>
          </Border>

          <Border Grid.Row="1"
                  Style="{StaticResource SidebarPaneBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
              <ScrollViewer.Resources>
                <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SidebarScrollBarStyle}"/>
              </ScrollViewer.Resources>
              <StackPanel>
                <TextBlock Text="运行" Style="{StaticResource SidebarSectionHeaderStyle}"/>
                <Button Style="{StaticResource SidebarNavButtonStyle}" Click="OneClickRegister_Click">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="PersonAdd24" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="一键注册" Style="{StaticResource SidebarLabelStyle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                  </Grid>
                </Button>
                <Button Style="{StaticResource SidebarNavButtonStyle}" Click="OneClickSms_Click">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="Chat24" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="一键接码" Style="{StaticResource SidebarLabelStyle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                  </Grid>
                </Button>
                <Button Style="{StaticResource SidebarNavButtonStyle}" Click="OneClickScan_Click">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="Search24" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="一键扫号" Style="{StaticResource SidebarLabelStyle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                  </Grid>
                </Button>
                <Button Style="{StaticResource SidebarNavButtonStyle}" Click="OneClickPay_Click">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="Money24" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="一键支付" Style="{StaticResource SidebarLabelStyle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                  </Grid>
                </Button>
                <Button Style="{StaticResource SidebarNavButtonStyle}" Click="OpenPayPalLink_Click">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="Link24" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="打开 PayPal 链接" Style="{StaticResource SidebarLabelStyle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                  </Grid>
                </Button>
                <Button Style="{StaticResource SidebarNavButtonStyle}" Click="MarkPayPalComplete_Click">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="CheckmarkCircle24" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="标记 PayPal 完成" Style="{StaticResource SidebarLabelStyle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                  </Grid>
                </Button>

                <TextBlock Text="管理" Style="{StaticResource SidebarSectionHeaderStyle}"/>
                <Button Style="{StaticResource SidebarNavButtonStyle}" Click="ImportPaidCpa_Click">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="ArrowImport24" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="一键导入" Style="{StaticResource SidebarLabelStyle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                  </Grid>
                </Button>
                <Button Style="{StaticResource SidebarNavButtonStyle}" Click="ExportAccounts_Click">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="ArrowExport24" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="导出账号" Style="{StaticResource SidebarLabelStyle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                  </Grid>
                </Button>
                <Button Style="{StaticResource SidebarNavButtonStyle}" Click="ReimportCpa401_Click">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="ArrowSync24" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="重导 CPA 401" Style="{StaticResource SidebarLabelStyle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                  </Grid>
                </Button>
                <Button Style="{StaticResource SidebarNavButtonStyle}" Click="RegeneratePayPalLink_Click">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="ArrowRedo24" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="重生 PayPal 链接" Style="{StaticResource SidebarLabelStyle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                  </Grid>
                </Button>
                <Button Style="{StaticResource SidebarNavButtonStyle}" Click="DeleteSelected_Click">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="Delete24" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="删除选中" Style="{StaticResource SidebarLabelStyle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                  </Grid>
                </Button>

                <TextBlock Text="邮箱" Style="{StaticResource SidebarSectionHeaderStyle}"/>
                <Button Style="{StaticResource SidebarNavButtonStyle}" Click="ImportChataiMailbox_Click">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="Mail24" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="导入邮箱" Style="{StaticResource SidebarLabelStyle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                  </Grid>
                </Button>
                <Button Style="{StaticResource SidebarNavButtonStyle}" Click="ViewInbox_Click">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="MailInbox24" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="查看收件箱" Style="{StaticResource SidebarLabelStyle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                  </Grid>
                </Button>
                <Button Style="{StaticResource SidebarNavButtonStyle}" Click="Refresh_Click">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="ArrowSync24" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="刷新" Style="{StaticResource SidebarLabelStyle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                  </Grid>
                </Button>
                <Button Style="{StaticResource SidebarNavButtonStyle}" Click="Settings_Click">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="Settings24" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="设置" Style="{StaticResource SidebarLabelStyle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                  </Grid>
                </Button>
                <Button Style="{StaticResource SidebarNavButtonStyle}" Click="ToggleTheme_Click">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="DarkTheme24" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="切换主题" Style="{StaticResource SidebarLabelStyle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                  </Grid>
                </Button>
                <Button Style="{StaticResource SidebarNavButtonStyle}" Click="CancelBatch_Click">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="DismissCircle24" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="取消批次" Style="{StaticResource SidebarLabelStyle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                  </Grid>
                </Button>
              </StackPanel>
            </ScrollViewer>
          </Border>
        </Grid>

        <Grid Grid.Column="1" Margin="14,0,14,10">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="320" MinHeight="240"/>
            <RowDefinition Height="24"/>
          </Grid.RowDefinitions>

          <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Margin="0,0,8,0" Padding="14,12" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1">
              <StackPanel>
                <TextBlock Text="总记录" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding TotalCountText}" FontSize="28" FontWeight="Bold"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Margin="0,0,8,0" Padding="14,12" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1">
              <StackPanel>
                <TextBlock Text="已接码" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding MailboxCountText}" FontSize="28" FontWeight="Bold"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="2" Margin="0,0,8,0" Padding="14,12" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1">
              <StackPanel>
                <TextBlock Text="已注册" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding RegisteredCountText}" FontSize="28" FontWeight="Bold"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="3" Margin="0,0,8,0" Padding="14,12" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1">
              <StackPanel>
                <TextBlock Text="支付完成" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding PaypalCountText}" FontSize="28" FontWeight="Bold"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="4" Padding="14,12" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1">
              <StackPanel>
                <TextBlock Text="异常/待处理" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding AttentionCountText}" FontSize="28" FontWeight="Bold"/>
              </StackPanel>
            </Border>
          </Grid>

          <Border Grid.Row="1" Margin="0,0,0,10" Padding="12" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1">
            <Grid VerticalAlignment="Center">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Grid Grid.Column="0" MinWidth="460">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="260"/>
                  <ColumnDefinition Width="140"/>
                  <ColumnDefinition Width="96"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="搜索邮箱、session、token、备注"/>
                <ComboBox Grid.Column="1" Margin="8,0,0,0" SelectedItem="{Binding ScopeFilter}">
                  <ComboBoxItem Content="全部"/>
                  <ComboBoxItem Content="邮箱池"/>
                  <ComboBoxItem Content="已注册"/>
                  <ComboBoxItem Content="待处理"/>
                </ComboBox>
                <TextBox Grid.Column="2" Margin="8,0,0,0" Text="{Binding PageSizeText, UpdateSourceTrigger=PropertyChanged}" ToolTip="每页条数"/>
                <TextBlock Grid.Column="3" Margin="12,0,0,0" Text="{Binding PageStatusText}" VerticalAlignment="Center" Foreground="{DynamicResource TextSub}"/>
              </Grid>
              <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="首页" Margin="4,0" Click="FirstPage_Click"/>
                <Button Content="上一页" Margin="4,0" Click="PrevPage_Click"/>
                <Button Content="清空选择" Margin="4,0" Click="ClearSelection_Click"/>
                <Button Content="下一页" Margin="4,0" Click="NextPage_Click"/>
                <Button Content="末页" Margin="4,0" Click="LastPage_Click"/>
                <Button Content="全选" Margin="4,0" Click="SelectAllFiltered_Click" ToolTip="选中当前筛选结果"/>
              </WrapPanel>
            </Grid>
          </Border>

          <Border Grid.Row="2" Margin="0,0,0,10" Padding="0" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1">
            <DataGrid x:Name="AccountGrid"
                      ItemsSource="{Binding PagedRows}"
                      SelectedItem="{Binding SelectedRow}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="28"
                      BorderThickness="0"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      SelectionChanged="AccountGrid_SelectionChanged">
              <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80" IsReadOnly="True"/>
                <DataGridCheckBoxColumn Header="选中" Binding="{Binding IsChecked}" Width="60"/>
                <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt}" Width="155" IsReadOnly="True"/>
                <DataGridTextColumn Header="更新时间" Binding="{Binding CompletedAt}" Width="155" IsReadOnly="True"/>
                <DataGridTextColumn Header="邮箱" Binding="{Binding Identifier}" Width="260" IsReadOnly="True"/>
                <DataGridTextColumn Header="类型" Binding="{Binding AccountType}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="130" IsReadOnly="True"/>
                <DataGridTextColumn Header="RT" Binding="{Binding RefreshTokenStatus}" Width="78" IsReadOnly="True"/>
                <DataGridTextColumn Header="支付状态" Binding="{Binding PayPalStatus}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="支付金额" Binding="{Binding PayPalAmount}" Width="95" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="详情" Width="70">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Button Content="查看" Height="24" Padding="6,0" Click="AccountDetail_Click"/>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </Border>

          <GridSplitter Grid.Row="3" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{DynamicResource SplitterBg}" ShowsPreview="True"/>

          <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="64" MinHeight="42"/>
              <RowDefinition Height="5"/>
              <RowDefinition Height="*" MinHeight="200"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Padding="0" CornerRadius="8" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1">
              <DataGrid x:Name="TaskGrid"
                        ItemsSource="{Binding Tasks}"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        HeadersVisibility="Column"
                        IsReadOnly="True"
                        RowHeight="26"
                        BorderThickness="0"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        Loaded="TaskGrid_Loaded">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="批次" Binding="{Binding Name}" Width="160"/>
                  <DataGridTextColumn Header="任务" Binding="{Binding Task}" Width="160"/>
                  <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90"/>
                  <DataGridTextColumn Header="参数" Binding="{Binding Info}" Width="520"/>
                  <DataGridTextColumn Header="耗时(s)" Binding="{Binding Cost}" Width="80"/>
                  <DataGridTextColumn Header="完成时间" Binding="{Binding DoneAt}" Width="150"/>
                </DataGrid.Columns>
              </DataGrid>
            </Border>
            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{DynamicResource SplitterBg}" ShowsPreview="True"/>
            <Border Grid.Row="2" Background="{DynamicResource LogBg}" BorderBrush="{DynamicResource LogBorder}" BorderThickness="1" CornerRadius="8">
              <Grid>
                <Button Width="74" Height="26" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,6,18,0" Padding="8,0" Panel.ZIndex="1" Click="ClearLog_Click">
                  <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource IconPath}" Width="13" Height="13" StrokeThickness="1.7"
                          Data="M3.5 5H12.5 M6 5V3.5H10V5 M5 6.5V13H11V6.5 M7 8V11.5 M9 8V11.5"/>
                    <TextBlock Text="清空" Margin="6,0,0,0" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <TextBox Text="{Binding LogText}" Background="{DynamicResource LogBg}" Foreground="{DynamicResource LogText}" BorderThickness="0"
                         FontFamily="Consolas" FontSize="12" IsReadOnly="True" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         VerticalAlignment="Stretch" HorizontalAlignment="Stretch" MinHeight="220" Padding="8,8,8,8"/>
              </Grid>
            </Border>
          </Grid>

          <Border Grid.Row="5" Background="{DynamicResource StatusBg}" BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0">
            <TextBlock Margin="8,3" Text="{Binding StatusText}" Foreground="{DynamicResource TextSub}"/>
          </Border>
        </Grid>
      </Grid>
    </Grid>
  </materialDesign:DialogHost>
</ui:FluentWindow>
