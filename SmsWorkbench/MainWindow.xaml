<ui:FluentWindow x:Class="SmsWorkbench.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                 xmlns:local="clr-namespace:SmsWorkbench"
                 xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
                 Title="GPT Register Tool"
                 Width="1420" Height="900" MinWidth="1240" MinHeight="760"
                 WindowStartupLocation="CenterScreen"
                 Background="{DynamicResource AppBg}"
                 FontFamily="Segoe UI, Microsoft YaHei UI"
                 FontSize="13"
                 UseLayoutRounding="True"
                 SnapsToDevicePixels="True"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
  <ui:FluentWindow.Resources>
    <local:CollapsedLabelConverter x:Key="CollapsedLabelConverter"/>

    <Style x:Key="WorkbenchCardStyle" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="16"/>
      <Setter Property="Padding" Value="16"/>
    </Style>

    <Style x:Key="StatCardStyle" TargetType="Border" BasedOn="{StaticResource WorkbenchCardStyle}">
      <Setter Property="MinHeight" Value="112"/>
      <Setter Property="Margin" Value="0,0,10,0"/>
    </Style>

    <Style x:Key="CommandBarStyle" TargetType="Border" BasedOn="{StaticResource WorkbenchCardStyle}">
      <Setter Property="Padding" Value="12"/>
      <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <Style x:Key="SidebarButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="MinWidth" Value="112"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="Margin" Value="0,0,8,8"/>
      <Setter Property="Padding" Value="12,0"/>
    </Style>

    <Style x:Key="SidebarIconButton" TargetType="Button" BasedOn="{StaticResource SidebarButton}">
      <Setter Property="MinWidth" Value="38"/>
      <Setter Property="Width" Value="38"/>
      <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="SidebarNavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="Height" Value="42"/>
      <Setter Property="Margin" Value="0,0,0,6"/>
      <Setter Property="Padding" Value="12,0"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>

    <Style x:Key="SidebarLabelStyle" TargetType="TextBlock">
      <Setter Property="Margin" Value="10,0,0,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding SidebarCollapsed}" Value="True">
          <Setter Property="Visibility" Value="Collapsed"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="SidebarSectionHeaderStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="4,16,0,8"/>
    </Style>
  </ui:FluentWindow.Resources>

  <materialDesign:DialogHost Identifier="RootDialogHost">
    <Grid Background="{DynamicResource AppBg}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <ui:TitleBar Grid.Row="0"
                   Title="GPT Register Tool"
                   Height="48"
                   Icon="Assets/app-icon.ico"
                   ShowMinimize="True"
                   ShowMaximize="True"
                   ShowClose="True">
        <ui:TitleBar.TrailingContent>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,130,0">
            <TextBlock Text="Win11 ????" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <ui:Button Content="????" Click="ToggleTheme_Click" Padding="12,0" Height="30"/>
          </StackPanel>
        </ui:TitleBar.TrailingContent>
      </ui:TitleBar>

      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition x:Name="SidebarColumn" Width="272"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ui:NavigationView x:Name="SidebarHost"
                           Grid.Column="0"
                           Margin="10,0,8,10"
                           PaneDisplayMode="Left"
                           OpenPaneLength="272"
                           CompactPaneLength="80"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="False"
                           IsPaneOpen="True"
                           HeaderVisibility="Collapsed"
                           IsTopSeparatorVisible="False"
                           IsFooterSeparatorVisible="False"
                           PaneTitle="GPT Register">
          <ui:NavigationView.PaneHeader>
            <Grid Margin="12,4,12,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Border Width="40" Height="40" CornerRadius="12" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1">
                <Image Source="Assets/black-kitten.png" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <StackPanel Grid.Column="1" Margin="10,0,8,0" VerticalAlignment="Center">
                <TextBlock Text="GPT Register" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="Account workbench" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
              </StackPanel>
              <Button x:Name="SidebarToggleButton" Grid.Column="2" Width="34" Height="34" Padding="0" Click="ToggleSidebar_Click" ToolTip="?????">
                <Path Width="16" Height="16" Stretch="Uniform" Data="{Binding SidebarToggleGeometry}" Stroke="{DynamicResource TextSub}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
              </Button>
            </Grid>
          </ui:NavigationView.PaneHeader>

          <ui:NavigationView.MenuItems>
            <ui:NavigationViewItem Content="????" Click="OneClickRegister_Click"/>
            <ui:NavigationViewItem Content="????" Click="OneClickSms_Click"/>
            <ui:NavigationViewItem Content="????" Click="OneClickScan_Click"/>
            <ui:NavigationViewItem Content="????" Click="OneClickPay_Click"/>
            <ui:NavigationViewItem Content="?? PayPal ??" Click="OpenPayPalLink_Click"/>
            <ui:NavigationViewItem Content="?? PayPal ??" Click="MarkPayPalComplete_Click"/>
            <ui:NavigationViewItem Content="AT ??" Click="AtExtractBaLink_Click"/>
            <ui:NavigationViewItem Content="????" Click="ImportPaidCpa_Click"/>
            <ui:NavigationViewItem Content="????" Click="ExportAccounts_Click"/>
            <ui:NavigationViewItem Content="?? PayPal ??" Click="RegeneratePayPalLink_Click"/>
            <ui:NavigationViewItem Content="????" Click="DeleteSelected_Click"/>
            <ui:NavigationViewItem Content="????" Click="ImportChataiMailbox_Click"/>
            <ui:NavigationViewItem Content="?????" Click="ViewInbox_Click"/>
          </ui:NavigationView.MenuItems>

          <ui:NavigationView.FooterMenuItems>
            <ui:NavigationViewItem Content="??" Click="Refresh_Click"/>
            <ui:NavigationViewItem Content="??" Click="Settings_Click"/>
            <ui:NavigationViewItem Content="????" Click="CancelBatch_Click"/>
          </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>

        <Page Grid.Column="1" Background="Transparent">
          <Grid Margin="10,0,14,10">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="6"/>
              <RowDefinition Height="300" MinHeight="220"/>
              <RowDefinition Height="26"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.45*"/>
              </Grid.ColumnDefinitions>

              <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                <StackPanel>
                  <TextBlock Text="???" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}"/>
                  <TextBlock Text="{Binding TotalCountText}" FontSize="30" FontWeight="SemiBold" Margin="0,6,0,0"/>
                  <TextBlock Text="??????" Foreground="{DynamicResource TextSub}"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Style="{StaticResource StatCardStyle}">
                <StackPanel>
                  <TextBlock Text="???" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}"/>
                  <TextBlock Text="{Binding MailboxCountText}" FontSize="30" FontWeight="SemiBold" Margin="0,6,0,0"/>
                  <TextBlock Text="??????" Foreground="{DynamicResource TextSub}"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                <StackPanel>
                  <TextBlock Text="???" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}"/>
                  <TextBlock Text="{Binding RegisteredCountText}" FontSize="30" FontWeight="SemiBold" Margin="0,6,0,0"/>
                  <TextBlock Text="Session / SQLite" Foreground="{DynamicResource TextSub}"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="3" Style="{StaticResource StatCardStyle}">
                <StackPanel>
                  <TextBlock Text="????" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}"/>
                  <TextBlock Text="{Binding PaypalCountText}" FontSize="30" FontWeight="SemiBold" Margin="0,6,0,0"/>
                  <TextBlock Text="PayPal / GoPay" Foreground="{DynamicResource TextSub}"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="4" Style="{StaticResource StatCardStyle}">
                <StackPanel>
                  <TextBlock Text="??/???" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}"/>
                  <TextBlock Text="{Binding AttentionCountText}" FontSize="30" FontWeight="SemiBold" Margin="0,6,0,0"/>
                  <TextBlock Text="??????" Foreground="{DynamicResource TextSub}"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="5" Style="{StaticResource StatCardStyle}" Margin="0">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="???" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="{Binding SuccessRateText}" FontSize="30" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    <TextBlock Text="?????????" Foreground="{DynamicResource TextSub}"/>
                  </StackPanel>
                  <lvc:PieChart Grid.Column="1" Series="{Binding OverviewPieSeries}" InitialRotation="-90" MaxAngle="360" LegendPosition="Hidden" TooltipPosition="Hidden"/>
                </Grid>
              </Border>
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource CommandBarStyle}">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ui:InfoBar Grid.Row="0" Title="????" Message="{Binding StatusText}" Severity="Informational" IsOpen="True" IsClosable="False" Margin="0,0,0,10"/>
                <Grid Grid.Row="1" VerticalAlignment="Center">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="96"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="?????session?token???"/>
                  <ComboBox Grid.Column="1" Margin="8,0,0,0" SelectedItem="{Binding ScopeFilter}">
                    <ComboBoxItem Content="??"/>
                    <ComboBoxItem Content="???"/>
                    <ComboBoxItem Content="???"/>
                    <ComboBoxItem Content="???"/>
                  </ComboBox>
                  <TextBox Grid.Column="2" Margin="8,0,0,0" Text="{Binding PageSizeText, UpdateSourceTrigger=PropertyChanged}" ToolTip="????"/>
                  <TextBlock Grid.Column="3" Margin="12,0,0,0" Text="{Binding PageStatusText}" VerticalAlignment="Center" Foreground="{DynamicResource TextSub}"/>
                  <WrapPanel Grid.Column="4" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ui:Button Content="??" Margin="4,0" Click="FirstPage_Click"/>
                    <ui:Button Content="???" Margin="4,0" Click="PrevPage_Click"/>
                    <ui:Button Content="????" Margin="4,0" Click="ClearSelection_Click"/>
                    <ui:Button Content="???" Margin="4,0" Click="NextPage_Click"/>
                    <ui:Button Content="??" Margin="4,0" Click="LastPage_Click"/>
                    <ui:Button Content="??" Margin="4,0" Click="SelectAllFiltered_Click" ToolTip="????????"/>
                  </WrapPanel>
                </Grid>
              </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource WorkbenchCardStyle}" Padding="0">
              <DataGrid x:Name="AccountGrid"
                        ItemsSource="{Binding PagedRows}"
                        SelectedItem="{Binding SelectedRow}"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        HeadersVisibility="Column"
                        GridLinesVisibility="Horizontal"
                        RowHeight="30"
                        BorderThickness="0"
                        SelectionMode="Extended"
                        SelectionUnit="FullRow"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        SelectionChanged="AccountGrid_SelectionChanged">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80" IsReadOnly="True"/>
                  <DataGridCheckBoxColumn Header="??" Binding="{Binding IsChecked}" Width="60"/>
                  <DataGridTextColumn Header="????" Binding="{Binding CreatedAt}" Width="155" IsReadOnly="True"/>
                  <DataGridTextColumn Header="????" Binding="{Binding CompletedAt}" Width="155" IsReadOnly="True"/>
                  <DataGridTextColumn Header="??" Binding="{Binding Identifier}" Width="260" IsReadOnly="True"/>
                  <DataGridTextColumn Header="??" Binding="{Binding AccountType}" Width="120" IsReadOnly="True"/>
                  <DataGridTextColumn Header="??" Binding="{Binding Status}" Width="130" IsReadOnly="True"/>
                  <DataGridTextColumn Header="RT" Binding="{Binding RefreshTokenStatus}" Width="78" IsReadOnly="True"/>
                  <DataGridTextColumn Header="????" Binding="{Binding PayPalStatus}" Width="120" IsReadOnly="True"/>
                  <DataGridTextColumn Header="????" Binding="{Binding PayPalAmount}" Width="95" IsReadOnly="True"/>
                  <DataGridTemplateColumn Header="??" Width="74">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <ui:Button Content="??" Height="24" Padding="8,0" Click="AccountDetail_Click"/>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
            </Border>

            <GridSplitter Grid.Row="3" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{DynamicResource SplitterBg}" ShowsPreview="True"/>

            <Grid Grid.Row="4" Margin="0,10,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="1.4*"/>
              </Grid.ColumnDefinitions>

              <Border Grid.Column="0" Style="{StaticResource WorkbenchCardStyle}" Padding="0">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  <TextBlock Text="????" FontWeight="SemiBold" Margin="14,0" VerticalAlignment="Center"/>
                  <DataGrid x:Name="TaskGrid"
                            Grid.Row="1"
                            ItemsSource="{Binding Tasks}"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            HeadersVisibility="Column"
                            IsReadOnly="True"
                            RowHeight="28"
                            BorderThickness="0"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Loaded="TaskGrid_Loaded">
                    <DataGrid.Columns>
                      <DataGridTextColumn Header="??" Binding="{Binding Name}" Width="130"/>
                      <DataGridTextColumn Header="??" Binding="{Binding Task}" Width="140"/>
                      <DataGridTextColumn Header="??" Binding="{Binding Status}" Width="90"/>
                      <DataGridTextColumn Header="??" Binding="{Binding Info}" Width="360"/>
                      <DataGridTextColumn Header="??(s)" Binding="{Binding Cost}" Width="80"/>
                      <DataGridTextColumn Header="????" Binding="{Binding DoneAt}" Width="150"/>
                    </DataGrid.Columns>
                  </DataGrid>
                </Grid>
              </Border>

              <Border Grid.Column="2" Background="{DynamicResource LogBg}" BorderBrush="{DynamicResource LogBorder}" BorderThickness="1" CornerRadius="16">
                <Grid>
                  <TextBlock Text="????" Foreground="{DynamicResource LogText}" FontWeight="SemiBold" Margin="14,10,0,0" Panel.ZIndex="1"/>
                  <ui:Button Content="??" Width="74" Height="28" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,16,0" Padding="8,0" Panel.ZIndex="1" Click="ClearLog_Click"/>
                  <TextBox Text="{Binding LogText}" Background="{DynamicResource LogBg}" Foreground="{DynamicResource LogText}" BorderThickness="0"
                           FontFamily="Consolas" FontSize="12" IsReadOnly="True" AcceptsReturn="True"
                           VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                           TextWrapping="NoWrap" Margin="8,40,8,8" Padding="8"/>
                </Grid>
              </Border>
            </Grid>

            <Border Grid.Row="5" Background="{DynamicResource StatusBg}" BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0">
              <TextBlock Margin="8,4" Text="{Binding StatusText}" Foreground="{DynamicResource TextSub}"/>
            </Border>
          </Grid>
        </Page>
      </Grid>
    </Grid>
  </materialDesign:DialogHost>
</ui:FluentWindow>
