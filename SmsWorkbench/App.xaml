<Application x:Class="SmsWorkbench.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Wpf.Ui;component/Resources/Wpf.Ui.xaml"/>
        <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Grey" SecondaryColor="Blue"/>
        <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml"/>
      </ResourceDictionary.MergedDictionaries>

      <!-- Semantic Color Palette (Warm Premium Light Theme) -->
      <SolidColorBrush x:Key="AppBg" Color="#F7F5F0"/>
      <SolidColorBrush x:Key="PanelBg" Color="#F0EEE8"/>
      <SolidColorBrush x:Key="PanelBg2" Color="#DDDAD4"/>
      <SolidColorBrush x:Key="PanelHover" Color="#E3E1DB"/>
      <SolidColorBrush x:Key="Line" Color="#DDDAD4"/>
      <SolidColorBrush x:Key="LineStrong" Color="#C5C2BA"/>
      <SolidColorBrush x:Key="Primary" Color="#3E3B36"/>
      <SolidColorBrush x:Key="PrimarySoft" Color="#E3E1DB"/>
      <SolidColorBrush x:Key="Danger" Color="#985248"/>
      <SolidColorBrush x:Key="DangerSoft" Color="#ECE2DC"/>
      <SolidColorBrush x:Key="DangerBorder" Color="#C49088"/>
      <SolidColorBrush x:Key="Success" Color="#3E846F"/>
      <SolidColorBrush x:Key="SuccessSoft" Color="#E0F3E6"/>
      <SolidColorBrush x:Key="SuccessBorder" Color="#8DC5A9"/>
      <SolidColorBrush x:Key="TextMain" Color="#3E3B36"/>
      <SolidColorBrush x:Key="TextSub" Color="#6B6860"/>
      <SolidColorBrush x:Key="TextMuted" Color="#9E9B93"/>
      <SolidColorBrush x:Key="SidebarBg" Color="#F0EEE8"/>
      <SolidColorBrush x:Key="GridAltBg" Color="#F7F5F0"/>
      <SolidColorBrush x:Key="SplitterBg" Color="#DDDAD4"/>
      <SolidColorBrush x:Key="StatusBg" Color="#F7F5F0"/>
      <SolidColorBrush x:Key="LogBg" Color="#3E3B36"/>
      <SolidColorBrush x:Key="LogBorder" Color="#55524C"/>
      <SolidColorBrush x:Key="LogText" Color="#E3E1DB"/>

      <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
      </Style>

      <Style x:Key="SectionLabel" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="6,14,0,7"/>
      </Style>

      <!-- Modernized Button Style -->
      <Style TargetType="Button">
        <Setter Property="Height" Value="32"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="Margin" Value="4,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="ButtonChrome"
                       Background="{TemplateBinding Background}"
                       BorderBrush="{TemplateBinding BorderBrush}"
                       BorderThickness="{TemplateBinding BorderThickness}"
                       CornerRadius="6">
                <ContentPresenter Margin="{TemplateBinding Padding}"
                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource PanelHover}"/>
                  <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource LineStrong}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource PanelBg2}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- PrimaryButton Style with clear Accent/Border -->
      <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LineStrong}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
      </Style>

      <!-- DangerButton Style with customized Red layout -->
      <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource DangerSoft}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DangerBorder}"/>
        <Setter Property="Foreground" Value="{DynamicResource Danger}"/>
      </Style>

      <Style x:Key="SidebarButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Height" Value="34"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
      </Style>

      <Style x:Key="SidebarIconButton" TargetType="Button" BasedOn="{StaticResource SidebarButton}">
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="0"/>
      </Style>

      <Style x:Key="PagerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Height" Value="32"/>
        <Setter Property="Margin" Value="3,0"/>
        <Setter Property="Padding" Value="10,0"/>
      </Style>

      <Style x:Key="IconPath" TargetType="Path">
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="Stroke" Value="{DynamicResource TextSub}"/>
        <Setter Property="StrokeThickness" Value="1.6"/>
        <Setter Property="StrokeStartLineCap" Value="Round"/>
        <Setter Property="StrokeEndLineCap" Value="Round"/>
        <Setter Property="StrokeLineJoin" Value="Round"/>
        <Setter Property="Fill" Value="Transparent"/>
      </Style>

      <!-- Modernized TextBox -->
      <Style TargetType="TextBox">
        <Setter Property="Height" Value="34"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource TextMain}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="TextBox">
              <Border x:Name="BoxChrome" Background="{TemplateBinding Background}"
                       BorderBrush="{TemplateBinding BorderBrush}"
                       BorderThickness="{TemplateBinding BorderThickness}"
                       CornerRadius="6">
                <ScrollViewer x:Name="PART_ContentHost"
                               Margin="{TemplateBinding Padding}"
                               VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                  <Setter TargetName="BoxChrome" Property="BorderBrush" Value="{DynamicResource LineStrong}"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Modernized ComboBox (property-only, uses WPF-UI built-in template) -->
      <Style TargetType="ComboBox">
        <Setter Property="Height" Value="34"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Cursor" Value="Hand"/>
      </Style>

      <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Cursor" Value="Hand"/>
      </Style>

      <!-- Modernized DataGrid -->
      <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="RowBackground" Value="{DynamicResource PanelBg}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridAltBg}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Line}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource Line}"/>
        <Setter Property="SelectionMode" Value="Extended"/>
        <Setter Property="CanUserResizeRows" Value="False"/>
      </Style>

      <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
        <Style.Triggers>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Background" Value="{DynamicResource PanelHover}"/>
          </Trigger>
          <Trigger Property="IsSelected" Value="True">
            <Setter Property="Background" Value="{DynamicResource PanelBg2}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
          </Trigger>
        </Style.Triggers>
      </Style>

      <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="DataGridCell">
              <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                       BorderThickness="0,0,1,1" Padding="{TemplateBinding Padding}">
                <ContentPresenter VerticalAlignment="Center"/>
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource PanelBg2}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSub}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="Height" Value="32"/>
      </Style>

      <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
      </Style>
    </ResourceDictionary>
  </Application.Resources>
</Application>
