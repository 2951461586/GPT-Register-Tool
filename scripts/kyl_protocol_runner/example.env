# Optional. Defaults to ./auths inside this package.
# AUTH_DIR=/absolute/path/to/CLIProxyAPI.git/auths

# Optional tuning.
PROTOCOL_WORKERS=2
DIRECT_CODEX_SAVE=1
CASDOOR_BRIDGE=kyl
HTTP_IMPERSONATE=chrome136
